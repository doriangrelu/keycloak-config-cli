# ── Keycloak connection ──────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_USER=admin
KEYCLOAK_PASSWORD=admin

# ── CLI version ─────────────────────────────────────────────────────
KC_CONFIG_CLI_VERSION=7.0.0

# ── Mustache variables ──────────────────────────────────────────────
# These variables are injected into {{…}} placeholders in YAML files.
# Each variable has a built-in default (see YAML files), so this file
# is only needed when you want to override them.
REALM_NAME=my-realm
ENVIRONMENT=dev
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8081
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=no-reply@example.com
